{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naseej.example/schemas/feature_contract.schema.json",
  "title": "Naseej Feature Contract",
  "description": "Canonical contract reconciling offline training features with the online node-local feature store. Generated by ml/src/feature_contract.py.",
  "type": "object",
  "additionalProperties": true,
  "required": ["contract_version", "feature_count", "features"],
  "properties": {
    "contract_version": { "type": "string" },
    "generated_by": { "type": "string" },
    "description": { "type": "string" },
    "dataset_note": { "type": "string" },
    "parity_statuses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "feature_count": { "type": "integer", "minimum": 1 },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/feature" }
    }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_name", "offline_name", "online_name", "dtype", "entity",
        "window", "aggregation", "definition", "bucket", "value_space",
        "point_in_time_safe", "leakage_risk", "privacy_level", "trainable",
        "servable", "explainable", "identity_memorization_risk",
        "parity_status", "lineage", "owner", "retention_days", "mismatch_notes"
      ],
      "properties": {
        "canonical_name": { "type": "string", "minLength": 1 },
        "offline_name": { "type": ["string", "null"] },
        "online_name": { "type": ["string", "null"] },
        "dtype": {
          "type": "string",
          "enum": ["int", "float", "flag", "bucket", "categorical_code"]
        },
        "entity": {
          "type": "string",
          "enum": ["account", "counterparty", "transaction", "graph_window", "bank_node"]
        },
        "window": { "type": "string" },
        "aggregation": { "type": "string" },
        "definition": { "type": "string" },
        "bucket": { "type": "string" },
        "value_space": { "type": "object" },
        "point_in_time_safe": { "type": "boolean", "const": true },
        "leakage_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "privacy_level": {
          "type": "string",
          "enum": ["pseudonymous-event", "pseudonymous-aggregate", "bucketed-aggregate"]
        },
        "trainable": { "type": "boolean" },
        "servable": { "type": "boolean" },
        "explainable": { "type": "boolean" },
        "identity_memorization_risk": { "type": "boolean" },
        "parity_status": {
          "type": "string",
          "enum": ["match", "name_only", "definition_mismatch", "train_only", "serve_only"]
        },
        "lineage": { "type": "string" },
        "owner": { "type": "string" },
        "retention_days": { "type": "integer", "minimum": 0 },
        "mismatch_notes": { "type": "string" }
      }
    }
  }
}
